{
  "title": "cmdAbl",
  "rules": [
    {
      "description": "Open cmdAbl command palette with ':' when Ableton Live is focused",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "period",
            "modifiers": {
              "mandatory": ["left_shift"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "/usr/bin/curl -s http://127.0.0.1:27184/open"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "com\\.ableton\\.live"
              ]
            }
          ]
        }
      ]
    }
  ]
}
